{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/user-prompt-submit.sh"}]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/on-instructions-loaded.sh"}]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/main-guard.sh"},
          {"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/tdd-guard.sh"}
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/phase-gate.sh"},
          {"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-stack.sh pre-spawn"}
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-before-commit.sh"},
          {"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/main-guard-bash.sh"}
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/log-event.sh post-tool"}]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/agent-logger.sh start"}]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/agent-logger.sh stop"}]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/on-stop-failure.sh"}]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/on-post-compact.sh"}]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/log-event.sh worktree-created"}]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/log-event.sh worktree-removed"}]
      }
    ]
  }
}
